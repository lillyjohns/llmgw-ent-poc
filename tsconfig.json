{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@proxy/*": ["./src/proxy/*"],
      "@admin/*": ["./src/admin/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "infra", "test"]
}
