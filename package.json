{
  "name": "llmgw-ent-poc",
  "version": "0.1.0",
  "description": "AWS-Native LLM Gateway Enterprise POC",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/proxy/server.ts",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.ts",
    "lint": "eslint src/ --ext .ts",
    "cdk:deploy": "cd infra && npx cdk deploy --all",
    "cdk:diff": "cd infra && npx cdk diff",
    "cdk:synth": "cd infra && npx cdk synth"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-comprehend": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-firehose": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "fastify": "^5.0.0",
    "js-tiktoken": "^1.0.15",
    "pino": "^9.0.0",
    "yaml": "^2.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
